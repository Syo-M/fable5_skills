{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sensitive-paths.mjs\"",
            "statusMessage": "Checking sensitive-path sign-off list"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sensitive-bash.mjs\"",
            "statusMessage": "Checking Bash command against sign-off list"
          }
        ]
      }
    ]
  }
}
